","唐氏","蜀中","经商","贸易","蜀中联盟"],["唐烈"]],"keywordsLength":2,"fitCount":1,"minDate":{"year":0,"month":7,"day":1},"maxDate":{"year":1,"month":1,"day":1}},"content":"唐门-事件(0年7月)：蜀地各个势力之间的连线被清理,唐氏主导的经商贸易恢复.","priority":100,"layer":100,"role":"user","id":32,"disabled":false},{"code":"event_fengdu_0y1m","name":"酆都鬼门关传说","matchType":"event","matchExpression":{"keywords":[["酆都","鬼城","鬼门关","蜀中","黄泉"],["范无咎","谢必安"]],"keywordsLength":2,"fitCount":1,"minDate":{"year":0,"month":1,"day":1},"maxDate":{"year":0,"month":5,"day":1}},"content":"酆都-事件(0年1月)：末日爆发,蜀中形成隐秘区域,流传鬼门关传说.","priority":100,"layer":100,"role":"user","id":40,"disabled":false},{"code":"event_fengdu_0y5m","name":"忘川奈何桥出现","matchType":"event","matchExpression":{"keywords":[["酆都","鬼城","忘川","奈何桥","黄泉","蜀中"],["范无咎","谢必安"]],"keywordsLength":2,"fitCount":1,"minDate":{"year":0,"month":5,"day":1},"maxDate":{"year":0,"month":7,"day":1}},"content":"酆都-事件(0年5月)：黄泉界地出现忘川,奈何桥.","priority":100,"layer":100,"role":"user","id":41,"disabled":false},{"code":"event_fengdu_0y7m","name":"黑白无常传闻","matchType":"event","matchExpression":{"keywords":[["酆都","鬼城","蜀中","黑衣","白衣","使者"],["范无咎","谢必安","黑无常","白无常"]],"keywordsLength":2,"fitCount":1,"minDate":{"year":0,"month":7,"day":1},"maxDate":{"year":1,"month":1,"day":1}},"content":"酆都-事件(0年7月)：有两位强者进入后未归,传闻有黑衣白衣使者出没.","priority":100,"layer":100,"role":"user","id":42,"disabled":false},{"code":"area_jiangnan","name":"江南","matchType":"normal","matchExpression":{"keywords":[["江南","水乡","姑苏","水榭","书院"],["南宫鹤","南宫灵","李清秋","荀逸之"]],"keywordsLength":2,"fitCount":1},"content":"地点-江南：地势低平,河道纵横,城市废墟半没于水泽,舟楫可通.","priority":100,"layer":100,"role":"user","id":50,"disabled":false},{"code":"location_nangongshijia","name":"南宫世家","matchType":"normal","matchExpression":{"keywords":[["南宫世家","南宫","姑苏水榭","江南","祖宅"],["南宫鹤","南宫灵"]],"keywordsLength":2,"fitCount":1},"content":"地点-江南-南宫世家：江南水乡传承数百年的家族,世代经营丝绸与茶叶贸易,商路遍布江南水网.末日时祖宅阵法自行启动,后扩建为姑苏水榭.","priority":100,"layer":100,"role":"user","id":51,"disabled":false},{"code":"location_xiaoshengxianzhuang","name":"小圣贤庄","matchType":"normal","matchExpression":{"keywords":[["小圣贤庄","圣贤庄","江南书院","书院","江南"],["李清秋","荀逸之"]],"keywordsLength":2,"fitCount":1},"content":"地点-江南-小圣贤庄：由读书人聚集而成的书院,以文入道,不擅武力争斗,掌握上古秘辛.原为江南书院,末日时幸存读书人聚于此地研究灵气与古籍.","priority":100,"layer":100,"role":"user","id":52,"disabled":false},{"code":"role_nangonghe","name":"南宫鹤","matchType":"normal","matchExpression":{"keywords":[["南宫鹤","南宫家主","南宫世家","江南","姑苏"],[]],"keywordsLength":2,"fitCount":1},"content":"角色-南宫鹤：南宫家主.男,五十二岁,清瘦儒雅,蓄短须,着素色长衫.原江南大学历史系教授,处事沉稳,善谋略,以保全家族为第一要务.专属:史学素养,祖传玉戒,紫檀烟斗.","priority":100,"layer":100,"role":"user","id":60,"disabled":false},{"code":"role_nangongling","name":"南宫灵","matchType":"normal","matchExpression":{"keywords":[["南宫灵","南宫世家","江南","高中","通灵"],[]],"keywordsLength":2,"fitCount":1},"content":"角色-南宫灵：南宫鹤幼女,江南书院学生.女,十七岁,齐肩短发参差不齐,杏眼目光躲闪,身形单薄.内向寡言,心思敏感,惯于角落观察.末日爆发时正值高二,觉醒通灵异能,可听懂兽语,感知鬼魂.专属:通灵异能,灵视,旧校牌.","priority":100,"layer":100,"role":"user","id":61,"disabled":false},{"code":"role_liqingqiu","name":"李清秋","matchType":"normal","matchExpression":{"keywords":[["李清秋","小圣贤庄","江南书院","江南","言灵","高中"],[]],"keywordsLength":2,"fitCount":1},"content":"角色-李清秋：江南书院学生.女,十八岁,青丝如瀑,眉眼温润,肤白如玉.温柔似水,待人接物和煦耐心,酷爱读书,内心自有丘壑.末日时于藏书楼觉醒言灵异能,诵读诗文可显化意境.专属:言灵异能,旧书卷,过目成诵.","priority":100,"layer":100,"role":"user","id":62,"disabled":false},{"code":"role_xunyizhi","name":"荀逸之","matchType":"normal","matchExpression":{"keywords":[["荀逸之","荀夫子","小圣贤庄","江南书院","江南","教授"],[]],"keywordsLength":2,"fitCount":1},"content":"角色-荀逸之：江南书院教授/小圣贤庄贤者.男,五十六岁,身形清癯,鬓发微霜,常着青灰色儒衫.原江南大学古典文献学教授,学识渊博,主张以文载道,以经典智慧解析灵气规则.后辈尊称荀夫子.专属:经典通义,浩然气,青衫(绣有隐秘护身符文).","priority":100,"layer":100,"role":"user","id":63,"disabled":false},{"code":"event_jiangnan_0y1m","name":"江南书院幸存者聚集","matchType":"event","matchExpression":{"keywords":[["江南书院","江南","书院","藏书楼","古籍"],["李清秋","荀逸之","南宫灵"]],"keywordsLength":2,"fitCount":1,"minDate":{"year":0,"month":1,"day":1},"maxDate":{"year":0,"month":3,"day":1}},"content":"江南书院-事件(0年1月)：末日爆发,周边学生携书逃至江南书院.","pr