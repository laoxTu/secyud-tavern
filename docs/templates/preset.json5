// docs/templates/preset.json5
{
  // 唯一标识符，建议格式 作者.预设名，如 alice.cat-girl
  id: "string",
  // 预设显示名称
  name: "string",
  // 版本
  version: "string",
  // 搜索标签，便于用户筛选
  tags: [
    "string"
  ],
  content: {
    author: "string",
    description: ""
  },
  entries: {
    // 世界书条目列表，相当于知识库
    lorebooks: [
      {
        // 条目唯一标识，在预设内不可重复
        id: "string",
        // 条目名称，可为空
        name: "string",
        match: {
          // 匹配类型：variable 变量表达式 / content 内容表达式 / constant 常量
          type: "string",
          // 匹配表达式，语法由 type 决定
          expression: "string",
        },
        // 命中后注入对话上下文的内容
        context: "string",
        priority: {
          // 层级，数值越大排序越靠前
          layer: "number",
          // 同层级内的排序，数值越大越靠前
          order: "number"
        },
        // 是否关闭条目
        disabled: "boolean"
      }
    ],
    // 正则替换规则列表
    regexes: [
      {
        // 规则唯一标识
        id: "string",
        // 规则名称
        name: "string",
        // 正则表达式
        pattern: "string",
        // 替换内容，支持捕获组 $1、$2 等
        replacement: "string",
        // 作用目标：input / output / both
        target: "string",
        layer: {
          // 生效的最小层数，从最新消息往回数，0 为最新
          min: "number",
          // 生效的最大层数，null 表示无上限
          max: "number",
        },
        // 是否禁用该规则，默认 false
        disabled: "boolean"
      }
    ],
    // 样式块列表，预设激活时按优先级注入
    styles: {
      // 样式块标识
      id: "string",
      // 样式名称
      name: "string",
      // 优先级，数值越小越先注入
      priority: "number",
      // CSS 代码
      content: "string",
      // 是否禁用css
      disabled: "boolean"
    },
    // 脚本块列表，预设激活时按优先级执行
    scripts: [
      {
        // 脚本块标识
        id: "string",
        // 脚本块名称
        name: "string",
        // 优先级，数值越小越先执行
        priority: "number",
        // JavaScript 代码
        content: "string",
        // 是否禁用script
        disabled: "boolean"
      }
    ]
  },
  // 依赖的预设 ID 列表，UI 可提示用户建议同时开启
  requires: [
    {
      presetId: "string",
      version: "string"
    }
  ],
}