// docs/templates/story.json5
{
  // 存档唯一标识符，UUID
  id: "string",
  // 用户自定义的存档名称
  name: "string",
  // 当前激活的预设ID列表
  presets: [
    {
      code: "string",
      version: "string"
    }
  ],
  // 对话消息记录
  entries: {
    history: [{
      id: "string",
      // 选择的ai回复
      aiIndex: "number",
      // 消息时间戳
      timestamp: "string",
      // 初始变量状态
      variables: "any",
      inputs: [{
        id: "string",
        // 消息正文
        content: "string",
        // 本轮产生的变量变更, json
        variableChanges: "any"
      }],
      outputs: [{
        id: "string",
        // 消息正文
        content: "string",
        // 本轮产生的变量变更, json
        variableChanges: "any"
      }]
    },

    ]
  },
  content: {
  }
}